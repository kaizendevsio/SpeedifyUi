{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8090"
      }
    }
  },
  "Probe": {
    "Enabled": true,
    "ApiKey": "",
    "IntervalMinutes": 10,
    "PriorityProbeIntervalSeconds": 60,
    "PriorityHintRetentionMinutes": 60,
    "Countries": ["sg", "hk", "jp", "ph"],
    "Cities": [],
    "IncludePremiumServers": true,
    "IncludePrivateServers": false,
    "MaxCandidatesPerCycle": 6,
    "MaxPriorityCandidatesPerCycle": 1,
    "SettleSeconds": 15,
    "SampleCount": 5,
    "SampleIntervalSeconds": 2,
    "PingTargets": ["1.1.1.1", "8.8.8.8"],
    "ThroughputTestUrls": ["https://speed.cloudflare.com/__down?bytes=5000000"],
    "ThroughputSampleBytes": 3000000,
    "ThroughputSampleCount": 2,
    "ThroughputParallelDownloads": 2,
    "ThroughputTimeoutSeconds": 10,
    "MaxThroughputMbps": 100,
    "MaxLatencyMs": 250,
    "MaxJitterMs": 80,
    "ScoreRetentionMinutes": 180
  }
}
