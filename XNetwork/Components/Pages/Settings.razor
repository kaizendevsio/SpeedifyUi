    private async Task HandleAdapterPriorityChange(string adapterId, string priority)
    {
        _isProcessing = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await SpeedifyService.SetPriorityAsync(adapterId, priority);

            // Update local state
            if (_adaptersExtended != null)
