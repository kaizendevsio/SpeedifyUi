    private void HandleAdapterMetricValueChange(string interfaceName, ChangeEventArgs e)
    {
        if (_systemAdapters == null) return;

        var adapter = _systemAdapters.FirstOrDefault(a => a.InterfaceName == interfaceName);
        if (adapter != null && int.TryParse(e.Value?.ToString(), out var metric))
        {
            adapter.Metric = Math.Clamp(metric, 1, 9999);
            StateHasChanged();
        }
    }

    private async Task ApplyAdapterMetric(AdapterRoutingPriority adapter)
    {
        if (string.IsNullOrEmpty(adapter.Gateway))
        {
            _error = "Cannot set metric: no gateway found for this adapter";
            return;
        }

        _isProcessing = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var success = await SpeedifyService.SetAdapterMetricAsync(
                adapter.InterfaceName,
                adapter.Metric,
                adapter.Gateway);

            if (success)
            {
                adapter.CurrentSystemMetric = adapter.Metric;

                // Update saved config
                var existing = _routingPriorityConfig.AdapterMetrics
                    .FirstOrDefault(m => m.InterfaceName == adapter.InterfaceName);
                if (existing != null)
                {
                    existing.Metric = adapter.Metric;
                }
                else
                {
                    _routingPriorityConfig.AdapterMetrics.Add(new AdapterMetricSetting
                    {
                        InterfaceName = adapter.InterfaceName,
                        Metric = adapter.Metric
                    });
                }

                _successMessage = $"Metric {adapter.Metric} applied to {adapter.InterfaceName}";
            }
            else
            {
                _error = $"Failed to set metric for {adapter.InterfaceName}";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error setting metric: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task MoveAdapterPriorityUp(AdapterRoutingPriority adapter)
    {
        if (adapter.Metric <= 1) return;

        // Decrease metric by 10 (or to 1 if would go below)
        adapter.Metric = Math.Max(1, adapter.Metric - 10);
        await ApplyAdapterMetric(adapter);
    }

    private async Task MoveAdapterPriorityDown(AdapterRoutingPriority adapter)
    {
        if (adapter.Metric >= 9999) return;

        // Increase metric by 10 (or to 9999 if would exceed)
        adapter.Metric = Math.Min(9999, adapter.Metric + 10);
        await ApplyAdapterMetric(adapter);
    }

