    }

    private async Task<bool> TryApplyCliSetting(Func<Task<bool>> cliCall, Action onSuccess, string failureMessage)
    {
        try
        {
            _error = null;
            var success = await cliCall();
            if (success)
            {
                onSuccess();
                return true;
            }

            _error = failureMessage;
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }

        return false;
    }

