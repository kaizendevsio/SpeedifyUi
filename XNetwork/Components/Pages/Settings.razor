    private string FormatAutoSwitchHealth()
    {
        if (_autoServerSwitchStatus.LastSuccessRate <= 0 && _autoServerSwitchStatus.LastLatencyMs <= 0)
        {
            return "Waiting for samples";
        }

        var health = $"{_autoServerSwitchStatus.LastLatencyMs:N0}ms latency, {_autoServerSwitchStatus.LastJitterMs:N0}ms jitter, {_autoServerSwitchStatus.LastSuccessRate:N0}% success";
        if (_autoServerSwitchStatus.HealthWindowSampleCount <= 0)
        {
            return health;
        }

        return $"{health}; window {_autoServerSwitchStatus.HealthWindowBadSampleCount}/{_autoServerSwitchStatus.HealthWindowSampleCount} bad";
    }

    private string FormatAutoSwitchLastSwitch()
    {
        if (!_autoServerSwitchStatus.LastSwitchUtc.HasValue)
        {
            return "No switch yet";
        }

        var localTime = _autoServerSwitchStatus.LastSwitchUtc.Value.ToLocalTime();
        var server = string.IsNullOrWhiteSpace(_autoServerSwitchStatus.LastSwitchServer)
            ? "unknown server"
            : _autoServerSwitchStatus.LastSwitchServer;
        return $"{localTime:g} to {server}";
    }

    private string FormatAutoSwitchProbeStatus()
    {
        if (string.IsNullOrWhiteSpace(_autoServerSwitchSettings.ProbeApiBaseUrl))
        {
            return "Not configured";
        }

        if (_autoServerSwitchStatus.IsCheckingProbe)
        {
            return "Checking scores";
        }

        if (!string.IsNullOrWhiteSpace(_autoServerSwitchStatus.ProbeApiError))
        {
            return _autoServerSwitchStatus.ProbeApiError;
        }

        if (_autoServerSwitchStatus.LastProbeRunUtc.HasValue)
        {
            return $"Last score run {_autoServerSwitchStatus.LastProbeRunUtc.Value.ToLocalTime():g}";
        }

        return "Waiting for scores";
    }

    private string FormatAutoSwitchRecommendation()
    {
        if (string.IsNullOrWhiteSpace(_autoServerSwitchStatus.RecommendedServer))
        {
            return "No recommendation";
        }

        return _autoServerSwitchStatus.RecommendedServerProbeScore.HasValue
            ? $"{_autoServerSwitchStatus.RecommendedServer} ({_autoServerSwitchStatus.RecommendedServerProbeScore.Value:N0}/100)"
            : _autoServerSwitchStatus.RecommendedServer;
    }

