<!-- Toggle Switch Component -->
<div class="toggle-switch">
    <label for="@Id" class="toggle-switch-label">@Label</label>
    <label class="toggle-switch-control">
        <input type="checkbox" id="@Id" class="toggle-switch-input" checked="@IsEnabled" @onchange="HandleToggle">
        <span class="toggle-switch-track"></span>
    </label>
</div>

@code {
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString();
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public bool IsEnabled { get; set; } = false;
    [Parameter] public EventCallback<bool> OnToggle { get; set; }

    private async Task HandleToggle(ChangeEventArgs e)
    {
        if (e.Value is bool newValue)
        {
            IsEnabled = newValue;
            await OnToggle.InvokeAsync(newValue);
        }
    }
}
