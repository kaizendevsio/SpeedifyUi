<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <TransitionableRoutePrimary RouteData="routeData" ForgetStateOnTransition="true" TransitionDurationMilliseconds="260">
                <TransitionableRouteView DefaultLayout="typeof(Layout.PageTransitionLayout)" />
            </TransitionableRoutePrimary>
            <TransitionableRouteSecondary RouteData="routeData" ForgetStateOnTransition="true" TransitionDurationMilliseconds="260">
                <TransitionableRouteView DefaultLayout="typeof(Layout.PageTransitionLayout)" />
            </TransitionableRouteSecondary>
        </LayoutView>
        <FocusOnNavigate RouteData="routeData" Selector="h1"/>
    </Found>
</Router>
