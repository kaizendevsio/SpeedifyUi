{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "MyHttpEndpoint": {
        "Url": "http://0.0.0.0:8080"
      }
    }
  },
  "NetworkMonitor": {
    "Enabled": true,
    "WhitelistedLinks": ["enxc8a3627e629b"],
    "DownTimeoutSeconds": 30,
    "MaxRestartAttemptsPerHour": 0,
    "RestartCooldownMinutes": 15
  },
  "AdapterRoutingPriority": {
    "Enabled": false,
    "ApplyOnStartup": false,
    "AdapterMetrics": []
  },
  "AutoServerSwitch": {
    "Enabled": false,
    "PreferredCountry": "sg",
    "PreferredCity": "singapore",
    "FallbackCountries": ["hk", "jp", "ph"],
    "IncludePremiumServers": true,
    "IncludePrivateServers": false,
    "CheckIntervalSeconds": 15,
    "DegradedSecondsBeforeSwitch": 90,
    "HealthWindowSeconds": 120,
    "MinimumBadSamplesInWindow": 3,
    "MinimumBadSampleRatio": 0.35,
    "RequireProbeCurrentServerBad": true,
    "CooldownMinutes": 10,
    "AvoidServerMinutes": 30,
    "MinimumConnectedAdaptersBeforeSwitch": 2,
    "RequiredRecommendationConfirmations": 2,
    "ProbeApiBaseUrl": "",
    "ProbeApiKey": "",
    "ProbeRequestTimeoutSeconds": 10,
    "ProbeMaxScoreAgeMinutes": 30,
    "MinimumProbeScore": 70,
    "MinimumScoreImprovement": 10,
    "MaxLatencyMs": 250,
    "MaxJitterMs": 80,
    "MinSuccessRate": 85
  }
}
